# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for dev — leave blank or set USE_POSTGRES=False)
USE_POSTGRES=False

# PostgreSQL (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/adhyeta_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── AI APIs (FREE tiers) ─────────────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# AI Model selection (can override defaults)
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash

# ─── Cloudinary (FREE tier) ───────────────────────────────────────────────────
# Get free account at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
